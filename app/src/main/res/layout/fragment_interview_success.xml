<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page">

    <!-- Success Lottie Animation -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottie_success"
        android:layout_width="340dp"
        android:layout_height="340dp"
        app:lottie_fileName="lottie_success.lottie"
        app:lottie_autoPlay="true"
        app:lottie_loop="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/tv_success_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.35" />

    <!-- Title -->
    <TextView
        android:id="@+id/tv_success_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="32dp"
        android:text="Interview Successfully Completed!"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:letterSpacing="-0.02"
        android:alpha="0"
        app:layout_constraintTop_toBottomOf="@+id/lottie_success"
        app:layout_constraintBottom_toTopOf="@+id/tv_success_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tv_success_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="40dp"
        android:text="Your answers have been recorded and are being analyzed. Check your reports for detailed feedback."
        android:textColor="@color/text_muted"
        android:textSize="15sp"
        android:textAlignment="center"
        android:lineSpacingMultiplier="1.4"
        android:alpha="0"
        app:layout_constraintTop_toBottomOf="@+id/tv_success_title"
        app:layout_constraintBottom_toTopOf="@+id/btn_view_reports"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- View Reports Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_view_reports"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="32dp"
        android:layout_marginHorizontal="32dp"
        android:text="View My Reports"
        android:textSize="15sp"
        android:textStyle="bold"
        android:alpha="0"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@+id/tv_success_subtitle"
        app:layout_constraintBottom_toTopOf="@+id/btn_go_home"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Go Home Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_go_home"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="48dp"
        android:text="Back to Home"
        android:textSize="15sp"
        android:alpha="0"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@+id/btn_view_reports"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
