<?xml version="1.0" encoding="utf-8"?>
<!-- Premium light Reset Password -->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:animateLayoutChanges="true"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="32dp">

        <!-- Back row -->
        <ImageView android:id="@+id/btn_back"
            android:layout_width="36dp" android:layout_height="36dp"
            android:background="@drawable/bg_accent_badge" android:padding="8dp"
            android:src="@drawable/ic_arrow_back" app:tint="@color/accent_indigo"
            android:layout_marginTop="8dp"
            android:clickable="true"
            android:focusable="true"
            android:stateListAnimator="@animator/scale_on_press"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView android:id="@+id/tv_back_label"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginStart="12dp" android:text="Back to Login"
            android:textColor="@color/text_link" android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@+id/btn_back"
            app:layout_constraintStart_toEndOf="@+id/btn_back"
            app:layout_constraintTop_toTopOf="@+id/btn_back" />

        <!-- Form card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_form"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/bg_white"
            app:layout_constraintTop_toBottomOf="@+id/btn_back">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">

                <TextView android:id="@+id/tv_title"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Reset Password"
                    android:textColor="@color/text_primary" android:textSize="26sp"
                    android:textStyle="bold" android:letterSpacing="-0.02"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView android:id="@+id/tv_description"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Enter the 6-digit code sent to your email and select a new password."
                    android:textColor="@color/text_secondary" android:textSize="14sp"
                    android:lineSpacingMultiplier="1.4"
                    app:layout_constraintTop_toBottomOf="@+id/tv_title" />

                <!-- 6 Digit Code Field -->
                <TextView android:id="@+id/tv_code_label"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="28dp" android:text="Reset Code"
                    android:textColor="@color/text_primary" android:textSize="13sp"
                    android:textStyle="bold" android:letterSpacing="0.02"
                    android:layout_marginBottom="10dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tv_description" />

                <EditText android:id="@+id/et_code"
                    android:layout_width="match_parent" android:layout_height="54dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input_selector"
                    android:hint="000000" android:inputType="number"
                    android:maxLength="6" android:letterSpacing="0.2"
                    android:gravity="center"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted" android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@+id/tv_code_label" />

                <!-- New Password Field -->
                <TextView android:id="@+id/tv_password_label"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="20dp" android:text="New Password"
                    android:textColor="@color/text_primary" android:textSize="13sp"
                    android:textStyle="bold" android:letterSpacing="0.02"
                    android:layout_marginBottom="10dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/et_code" />

                <FrameLayout
                    android:id="@+id/layout_password"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input_field"
                    app:layout_constraintTop_toBottomOf="@+id/tv_password_label">
                    <EditText
                        android:id="@+id/et_new_password"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:paddingStart="18dp"
                        android:paddingEnd="52dp"
                        android:hint="••••••••"
                        android:inputType="textPassword"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_muted"
                        android:textSize="15sp"/>
                    <ImageView
                        android:id="@+id/iv_eye"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center_vertical|end"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/ic_eye"
                        app:tint="@color/text_muted"/>
                </FrameLayout>

                <TextView android:id="@+id/tv_confirm_password_label"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="20dp" android:text="Confirm Password"
                    android:textColor="@color/text_primary" android:textSize="13sp"
                    android:textStyle="bold" android:letterSpacing="0.02"
                    android:layout_marginBottom="10dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/layout_password" />

                <FrameLayout
                    android:id="@+id/layout_confirm_password"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input_field"
                    app:layout_constraintTop_toBottomOf="@+id/tv_confirm_password_label">
                    <EditText
                        android:id="@+id/et_confirm_password"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:paddingStart="18dp"
                        android:paddingEnd="52dp"
                        android:hint="••••••••"
                        android:inputType="textPassword"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_muted"
                        android:textSize="15sp"/>
                    <ImageView
                        android:id="@+id/iv_eye_confirm"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center_vertical|end"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/ic_eye"
                        app:tint="@color/text_muted"/>
                </FrameLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_reset_password"
                    android:layout_width="match_parent" android:layout_height="54dp"
                    android:layout_marginTop="32dp"
                    android:background="@drawable/bg_gradient_button"
                    android:text="Update Password"
                    android:textAllCaps="false" android:textColor="@color/text_on_accent"
                    android:textSize="16sp" android:textStyle="bold"
                    android:stateListAnimator="@animator/scale_on_press"
                    app:backgroundTint="@null" app:cornerRadius="14dp"
                    app:layout_constraintTop_toBottomOf="@+id/layout_confirm_password" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
