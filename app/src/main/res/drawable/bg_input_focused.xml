<?xml version="1.0" encoding="utf-8"?>
<!-- Focused input field — white bg, indigo border glow -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer slight spread/glow -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke android:width="4dp" android:color="#265C6BC0" /> <!-- 15% opacity Indigo -->
            <corners android:radius="16dp" />
        </shape>
    </item>
    <!-- Actual prominent border -->
    <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <stroke android:width="2dp" android:color="#5C6BC0" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</layer-list>
